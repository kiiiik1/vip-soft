{
  "name": "developer-tools-bundle",
  "version": "1.0.0",
  "description": "A comprehensive toolkit for developers including batch file renaming and code quality checking",
  "main": "main.py",
  "scripts": {
    "demo": "python demo_tools.py",
    "batch-rename": "python batch_renamer.py",
    "code-quality": "python code_quality_checker.py",
    "test": "python -m pytest tests/"
  },
  "keywords": [
    "developer-tools",
    "batch-rename",
    "code-quality",
    "productivity",
    "utilities"
  ],
  "author": "Developer Tools Bundle Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/developer-tools-bundle.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/developer-tools-bundle/issues"
  },
  "homepage": "https://github.com/your-username/developer-tools-bundle",
  "dependencies": {
    "python": ">=3.6"
  },
  "devDependencies": {
    "pytest": "^6.0.0",
    "black": "^21.0.0",
    "flake8": "^3.8.0"
  },
  "engines": {
    "node": ">=12.0.0"
  },
  "files": [
    "batch_renamer.py",
    "batch_renamer_simple.py",
    "code_quality_checker.py",
    "demo_tools.py",
    "README.md",
    "LICENSE"
  ],
  "config": {
    "github": {
      "app_name": "Developer-Tools-Bundle",
      "webhook_url": "https://your-domain.com/webhook",
      "permissions": {
        "metadata": "read",
        "contents": "read",
        "pull_requests": "write"
      }
    },
    "gumroad": {
      "product_name": "Developer Tools Bundle",
      "price_personal": 4.99,
      "price_professional": 9.99,
      "price_enterprise": 19.99,
      "currency": "USD"
    }
  }
}